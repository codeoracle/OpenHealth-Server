# Database (pick one for production — MongoDB is recommended)
#
# Local dev: leave MONGODB_URI and DATABASE_URL empty → SQLite (no setup).
#
# Production (Render): set MONGODB_URI from MongoDB Atlas (free tier).
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/openhealth
MONGODB_URI=
#
# Alternative: Postgres instead of MongoDB (only used when MONGODB_URI is empty).
DATABASE_URL=
DATABASE_SSL=true
#
# SQLite file path (only when neither URI above is set).
DATABASE_PATH=./data/openhealth.db

# Server
PORT=5400

# Provider order — tries each in sequence until one works
# groq = free tier | mock = demo responses when all APIs fail
LLM_PROVIDERS=groq,openai,claude,mock
ENABLE_MOCK_LLM=true

# Groq (FREE — get key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (requires billing credits)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude (requires billing credits)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-haiku-20241022
